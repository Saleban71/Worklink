# Copy to app/.env and fill in from your Supabase project settings
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-side only (supabase secrets set ...), never shipped in the app
ANTHROPIC_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
